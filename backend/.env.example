# FactoryLink Backend Environment
# Copy this to .env and fill in real values

# Server
PORT=3000
NODE_ENV=development

# PostgreSQL (Supabase)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres
DB_HOST=db.YOUR_PROJECT.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=YOUR_PASSWORD
DB_SSL=true

# Redis
REDIS_URL=redis://localhost:6379

# JWT Secrets
JWT_SECRET=your_jwt_secret_change_this_in_production
JWT_REFRESH_SECRET=your_refresh_secret_change_this
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Firebase FCM
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_SERVICE_ACCOUNT=./config/firebase-service-account.json

# Gupshup (WhatsApp/SMS)
GUPSHUP_API_KEY=your_gupshup_api_key
GUPSHUP_APP_NAME=FactoryLink
GUPSHUP_SENDER_ID=FCTLNK

# Google Maps
GOOGLE_MAPS_API_KEY=your_google_maps_key

# Amazon S3
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=ap-south-1
AWS_S3_BUCKET=factorylink-uploads

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
